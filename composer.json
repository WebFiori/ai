{
    "name": "webfiori/ai",
    "type": "library",
    "description": "Provider-agnostic AI library for PHP. Supports chat completions, embeddings, image generation, tool calling, and streaming across multiple providers.",
    "keywords": [
        "AI",
        "LLM",
        "PHP",
        "OpenAI",
        "Vertex AI",
        "Anthropic",
        "Bedrock",
        "Chat",
        "Embeddings",
        "Streaming"
    ],
    "version": "0.1.0",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "WebFiori\\Ai\\": "WebFiori/Ai"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebFiori\\Tests\\Ai\\": "tests/WebFiori/Tests/Ai/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration tests/phpunit.xml",
        "fix-cs": "php-cs-fixer fix --config=php_cs.php.dist"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.92"
    }
}
